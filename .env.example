# Object Life — YouTube Automation
# =============================================
# Copy this file to .env and fill in your values.
# The .env file is NEVER committed to git (.gitignore handles this).

# ── Gemini AI ─────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ── YouTube OAuth 2.0 ─────────────────────────
# Download the JSON from Google Cloud Console and
# place it at the project root as youtube_credentials.json.
# No extra env vars needed beyond the credentials file.

# ── Facebook ──────────────────────────────────
FACEBOOK_ENABLED=false
FACEBOOK_PAGE_ID=YOUR_PAGE_ID
FACEBOOK_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
FACEBOOK_APP_ID=YOUR_APP_ID
FACEBOOK_APP_SECRET=YOUR_APP_SECRET

# ── Instagram ─────────────────────────────────
INSTAGRAM_ENABLED=false
INSTAGRAM_USERNAME=YOUR_USERNAME
INSTAGRAM_PASSWORD=YOUR_PASSWORD

# ── TikTok ────────────────────────────────────
TIKTOK_ENABLED=false
TIKTOK_SESSION_ID=YOUR_SESSION_COOKIE_VALUE
